DATABASE_URL=file:./data/hooklens.db
PORT=3000
APP_URL=http://localhost:3000

# Local file (default) — WAL + cache pragmas applied automatically
# DATABASE_URL=file:./data/hooklens.db

# Embedded replica — local reads, remote writes (Turso)
# DATABASE_URL=file:./data/hooklens.db
# DATABASE_SYNC_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token
# DATABASE_SYNC_INTERVAL=60

# Remote only — no local file
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token
# DATABASE_CONCURRENCY=20
